# ==================================================
# YOUTUBE PLATFORM - ENVIRONMENT TEMPLATE
# ==================================================

# --- GENERAL ---
NODE_ENV=development
PORT=3000

# --- AUTHENTICATION ---
# Generate strong secrets for production: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- DATABASE ---
POSTGRES_USER=yt_user
POSTGRES_PASSWORD=
POSTGRES_DB=youtube_db
DATABASE_URL=postgres://yt_user:PASSWORD@localhost:5432/youtube_db

# --- CACHE ---
REDIS_URL=redis://localhost:6379

# --- EXTERNAL APIS ---
PIPED_WHITELIST=pipedapi.kavin.rocks,pipedapi.rivo.gg
